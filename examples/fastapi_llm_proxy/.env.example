# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Redis timeouts / pool.
# Invariant: SEMAPHORE_BLPOP_TIMEOUT < REDIS_SOCKET_TIMEOUT < SEMAPHORE_LOCK_TIMEOUT
REDIS_SOCKET_TIMEOUT=10
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_MAX_CONNECTIONS=64

# Semaphore (per client_id+model)
SEMAPHORE_CAPACITY=5
SEMAPHORE_LOCK_TIMEOUT=120
SEMAPHORE_ACQUIRE_TIMEOUT=200
SEMAPHORE_BLPOP_TIMEOUT=3
SEMAPHORE_NAMESPACE=llm_proxy

# Redis availability check (recovery poll interval while down)
REDIS_CHECK_INTERVAL=5

# Upstream LLM API
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_TIMEOUT=120
CLIENT_MODEL_CONFIG_PATH=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/llm_proxy.jsonl
